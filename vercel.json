{
  "version": 2,
  "buildCommand": "cd frontend && bash vercel-build.sh",
  "outputDirectory": "frontend/build/web",
  "installCommand": "echo 'skip'",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
