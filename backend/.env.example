# App
NODE_ENV=production
PORT=3000
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=gamelearn
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE=gamelearn
DB_SSL=false

# JWT
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_SECRET_32_CHARS_MINIMUM
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_REFRESH_SECRET
JWT_REFRESH_EXPIRY=30d

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Storage (MinIO)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
STORAGE_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
STORAGE_BUCKET=gamelearn
STORAGE_PUBLIC_URL=https://storage.yourdomain.com

# AI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4-turbo-preview
GEMINI_API_KEY=your-gemini-key-here

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Frontend
FRONTEND_URL=https://yourdomain.com
